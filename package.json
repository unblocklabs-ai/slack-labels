{
  "name": "@unblocklabs/slack-labels",
  "version": "0.1.0",
  "description": "OpenClaw plugin that labels persisted Slack user messages with sender identity.",
  "type": "module",
  "license": "MIT",
  "author": "Unblock Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unblocklabs-ai/slack-labels.git"
  },
  "homepage": "https://github.com/unblocklabs-ai/slack-labels#readme",
  "bugs": {
    "url": "https://github.com/unblocklabs-ai/slack-labels/issues"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "openclaw.plugin.json",
    "plugin-inspector.config.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "check:runtime": "npm run build && npm run typecheck && npm test",
    "plugin:inspect": "plugin-inspector check --config plugin-inspector.config.json --no-openclaw",
    "plugin:inspect:runtime": "plugin-inspector check --config plugin-inspector.config.json --no-openclaw --runtime --mock-sdk --allow-execute",
    "pack:check": "npm pack --dry-run",
    "preflight": "npm run check:runtime && npm run plugin:inspect && npm run plugin:inspect:runtime && npm run pack:check"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "slack",
    "transcript",
    "attribution"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.3"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@openclaw/plugin-inspector": "^0.3.11",
    "@types/node": "^24.6.0",
    "openclaw": "2026.5.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.3",
      "minGatewayVersion": ">=2026.5.3"
    },
    "install": {
      "clawhubSpec": "clawhub:@unblocklabs/slack-labels",
      "npmSpec": "@unblocklabs/slack-labels",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.5.3"
    },
    "build": {
      "openclawVersion": "2026.5.3",
      "pluginSdkVersion": "2026.5.3"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
